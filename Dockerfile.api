# Stage 1: Build the binary
FROM golang:1.26-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o server cmd/server/main.go cmd/server/handlers.go

# Stage 2: Final lightweight execution layer
FROM alpine:latest
WORKDIR /root/
COPY --from=builder /app/server .
COPY --from=builder /app/cmd/server/static ./cmd/server/static
EXPOSE 8080
CMD ["./server"]